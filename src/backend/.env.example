# --- HTTP ---
# Optional locally: omit PORT to use the dev default (8080). In production, Zeabur/Docker/Kubernetes
# set PORT — do not commit real values here.
# PORT=8080

# Required in production (set in the platform dashboard or orchestration). Dev may omit (fallback in code).
JWT_SECRET=change-me-to-a-long-random-string
# Sign-in uses MongoDB `ClubMaster_DB.userLogin` when MONGODB_URI (etc.) is set — see DBConnection.ts / authRoutes.ts.
# Legacy CSV login files are not shipped under `backend/data/`. Optional overrides if you still point code at local CSVs:
# USERLOGIN_CSV_PATH=./path/to/userLogin.csv
# USERLIST_CSV_PATH=./path/to/userLogin.csv
# USERLOGIN_COACH_CSV_PATH=./path/to/userLogin_Coach.csv
# USERLOGIN_STUDENT_CSV_PATH=./path/to/userLogin_Student.csv
# Optional: absolute or cwd-relative folder for club CSVs (default: backend/data_club next to server code)
# DATA_CLUB_ROOT=D:/path/to/Sport Coach/backend/data_club

# Optional: prize list file folder (default: logged-in club UID → backend/data_club/{UID}/PrizeList.json)
# PRIZE_LIST_STORAGE_CLUB_ID=CM00000001
# Debug: extra `debug` fields on coach-manager API + auth errors, and server logs (do not use in production)
# SPORT_COACH_DEBUG=1

# --- AWS RDS PostgreSQL (optional; see src/db/rdsPostgres.ts) ---
# Download CA bundle once: npm run rds:download-ca  → backend/certs/global-bundle.pem
# RDS_HOST=sport-master-db.cluster-cjsyqwwa4dr6.ap-southeast-2.rds.amazonaws.com
# RDS_PORT=5432
# RDS_DATABASE=postgres
# RDS_USER=metaservices
# RDS_PASSWORD=your-secret-password
# Optional: override CA path (default backend/certs/global-bundle.pem)
# RDS_SSL_CA_PATH=./certs/global-bundle.pem
# RDS_POOL_MAX=10

# --- MongoDB (optional; see src/db/DBConnection.ts + npm run mongo:seed-user-login) ---
# Copy this file to `.env` in the same folder (`src/backend/.env`). Scripts load it only when NODE_ENV is not `production`.
# Option A — full connection string (Zeabur / Atlas):
# MONGODB_URI=mongodb://USER:PASSWORD@HOST:PORT/
# Option B — password only (optional MONGO_HOST / MONGO_PORT / MONGO_USER override defaults in DBConnection.ts):
# MONGO_PASSWORD=your-mongo-password
# App MongoDB database name (collections: userLogin, clubInfo, …). Default when unset: ClubMaster_DB.
# MONGO_DATABASE=ClubMaster_DB
# Optional override for login-related collections only (otherwise MONGO_DATABASE or default applies):
# MONGO_USERLOGIN_DB=ClubMaster_DB
#
# Sign-in uses the same DB as MONGO_USERLOGIN_DB / MONGO_DATABASE (default ClubMaster_DB).
# Set only if sign-in must read `userLogin` from a different database than the rest of the app:
# MONGO_AUTH_USERLOGIN_DB=OtherDbName
#
# One-time copy: DB userLogin → DB ClubMaster_DB (optional `--dry-run` after the `--`):
#   `userLogin` collection: npm run mongo:clone-userlogin
#   `clubInfo` collection: npm run mongo:clone-clubinfo
# MONGO_CLONE_SOURCE_DB=userLogin
# MONGO_CLONE_TARGET_DB=ClubMaster_DB
#
# Import `data/BasicInfo.json` → Mongo `basicInfo` collection (`npm run mongo:seed-basicinfo-json`).
# Optional: override DB for `basicInfo` only (default: ClubMaster_DB, see resolveBasicInfoDatabaseName):
# MONGO_BASICINFO_TARGET_DB=ClubMaster_DB
# BASICINFO_JSON_PATH=./data/BasicInfo.json
#
# Import `data_club/{clubId}/LessonList.json` → Mongo `LessonList` (`npm run mongo:seed-lessonlist-json`):
# LESSONLIST_JSON_PATH=./data_club/CM00000003/LessonList.json
# MONGO_LESSONLIST_TARGET_DB=ClubMaster_DB
#
# Club roster Mongo collections `UserList_Coach` / `UserList_Student` (default DB ClubMaster_DB):
# MONGO_USERLIST_ROSTER_TARGET_DB=ClubMaster_DB
# USERLIST_COACH_JSON_PATH=./data_club/CM00000003/UserList_Coach.json
